# Template de configuração para deploy
# Copie este arquivo para deploy.env e preencha com seus valores reais.
# O arquivo deploy.env NUNCA deve ser commitado (está no .gitignore).

# Caminho para a chave SSH privada do VPS
# Windows (PowerShell):  C:\Users\voce\Downloads\chave.key
# Git Bash / WSL / Linux: /c/Users/voce/Downloads/chave.key
DEPLOY_SSH_KEY=CAMINHO/PARA/SUA/CHAVE_SSH.key

# Host SSH do VPS (formato: usuario@IP)
DEPLOY_SSH_HOST=ubuntu@SEU_IP_VPS
