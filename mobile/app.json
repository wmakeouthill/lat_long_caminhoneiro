{
  "expo": {
    "name": "Rastreamento",
    "slug": "lat-long-caminhoneiro",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "latlong",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "android": {
      "googleServicesFile": "./google-services.json",
      "package": "com.latlong.caminhoneiro",
      "newArchEnabled": true,
      "adaptiveIcon": {
        "backgroundColor": "#1a1a2e"
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION"
      ]
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ],
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.775387193989-saukr5aotr2doa1b2je6ujl2cqap6rua"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Rastreamento precisa de acesso à localização em segundo plano para enviar sua posição.",
          "locationAlwaysPermission": "Rastreamento precisa de acesso à localização em segundo plano.",
          "locationWhenInUsePermission": "Rastreamento precisa da sua localização."
        }
      ]
    ],
    "extra": {
      "apiUrl": "http://SEU_IP_VPS",
      "googleWebClientId": "775387193989-saukr5aotr2doa1b2je6ujl2cqap6rua.apps.googleusercontent.com",
      "eas": {
        "projectId": "8b5384a2-7997-4750-b9e3-8c959750d0f1"
      }
    },
    "owner": "wmakeouthill"
  }
}
